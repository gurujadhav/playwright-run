{
  "ts-node": {
    "files": true
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "baseUrl": "."
  },
  "include": [
    "features/**/*.ts",
    "page-objects/**/*.ts",
    "settings/**/*.ts",
    "shared-objects/**/*.ts",
    "step-definitions/**/*.ts",
    "test-data/**/*.ts",
    "types/**/*.ts",
    ".envConfigrc.ts",
    ".dataConfigrc.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
